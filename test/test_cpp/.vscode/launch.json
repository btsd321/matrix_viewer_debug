{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++ Demo (MSVC / cppvsdbg)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_msvc/Debug/demo.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "environment": [],
            "console": "internalConsole"
        },
        {
            "name": "C++ Demo (GCC / cppdbg + gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_gcc/demo",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "C++ Demo (LLVM / cppdbg + lldb-mi)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_llvm/demo.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "MIMode": "lldb",
            "miDebuggerPath": "C:/Program Files/LLVM/bin/lldb-mi.exe",
            "environment": [
                {
                    "name": "PATH",
                    "value": "D:/Library/vcpkg/installed/x64-windows/debug/bin;C:/Program Files/LLVM/bin;${env:PATH}"
                }
            ]
        },
        {
            "name": "C++ Demo (LLVM / CodeLLDB)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build_llvm/demo.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false,
            "env": {
                "PATH": "D:/Library/vcpkg/installed/x64-windows/debug/bin;C:/Program Files/LLVM/bin;${env:PATH}"
            }
        }
    ]
}
