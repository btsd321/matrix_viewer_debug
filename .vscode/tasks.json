{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "problemMatcher": [
        {
          "owner": "esbuild",
          "pattern": {
            "regexp": "^(ERROR|WARNING)\\s.*:\\s(.+):(\\d+):(\\d+):\\s(.+)$",
            "severity": 1,
            "file": 2,
            "line": 3,
            "column": 4,
            "message": 5
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "\\[watch\\] build started",
            "endsPattern": "\\[watch\\] build finished"
          }
        }
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
